# Hedera operator credentials (server-side only)
HEDERA_ACCOUNT_ID=0.0.xxxx
HEDERA_PRIVATE_KEY=
HEDERA_NETWORK=testnet

# LLM provider & model
#   LLM_PROVIDER  must be: openai | anthropic
#   LLM_MODEL     defaults: openai -> gpt-4o-mini, anthropic -> claude-haiku-4-5
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# LLM API keys (set the one matching LLM_PROVIDER above)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
